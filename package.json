{
  "name": "front-pdf-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "ts.check": "tsc",
    "test": "jest"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "mammoth": "^1.12.0",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0",
    "react-test-renderer": "^19.2.7"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
